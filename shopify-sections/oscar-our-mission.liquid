{% comment %}
  ============================================
  SHOPIFY SECTION: OUR MISSION
  Paste into: Sections > Add new section > "oscar-our-mission"
  ============================================
{% endcomment %}

<section class="oscar-mission" id="oscar-mission-{{ section.id }}">
  <div class="oscar-mission__inner">
    <div class="oscar-mission__head">
      <div>
        <p class="oscar-mission__eyebrow oscar-reveal">{{ section.settings.eyebrow }}</p>
        <h2 class="oscar-mission__heading oscar-reveal">{{ section.settings.heading | newline_to_br }}</h2>
      </div>
      <p class="oscar-mission__pull oscar-reveal">{{ section.settings.subheading }}</p>
    </div>

    <div class="oscar-mission__cards">
      {%- for block in section.blocks -%}
        <div class="oscar-mission__card oscar-reveal" {{ block.shopify_attributes }}>
          <div class="oscar-mission__num">{{ block.settings.number }}</div>
          <h3 class="oscar-mission__card-title">{{ block.settings.title }}</h3>
          <p class="oscar-mission__card-body">{{ block.settings.body }}</p>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="oscar-mission__more">
              <span>READ MORE</span>
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #oscar-mission-{{ section.id }} {
    background-color: #F9F4EC;
    background-image: radial-gradient(circle at 20% 30%, rgba(200,129,46,0.04), transparent 40%),
                      radial-gradient(circle at 80% 70%, rgba(28,43,74,0.03), transparent 40%);
    padding: 4rem 0; font-family: 'Montserrat', sans-serif;
  }
  @media (min-width: 768px) { #oscar-mission-{{ section.id }} { padding: 6rem 0; } }
  @media (min-width: 1024px) { #oscar-mission-{{ section.id }} { padding: 7rem 0; } }
  #oscar-mission-{{ section.id }} .oscar-mission__inner { max-width: 80rem; margin: 0 auto; padding: 0 1.5rem; }

  .oscar-mission__head { display: grid; grid-template-columns: 1fr; gap: 2.5rem; margin-bottom: 3rem; align-items: end; }
  @media (min-width: 1024px) { .oscar-mission__head { grid-template-columns: 7fr 5fr; margin-bottom: 4rem; } }

  .oscar-mission__eyebrow { font-weight: 700; font-size: 11px; letter-spacing: 0.25em; text-transform: uppercase; color: #C8812E; margin: 0 0 1rem; }
  .oscar-mission__heading {
    font-family: 'Montserrat', sans-serif; font-weight: 900; text-transform: uppercase;
    color: #1C2B4A; margin: 0; line-height: 0.95; letter-spacing: -2px;
    font-size: 48px;
  }
  @media (min-width: 768px) { .oscar-mission__heading { font-size: 80px; } }
  @media (min-width: 1024px) { .oscar-mission__heading { font-size: 96px; } }
  .oscar-mission__pull { font-family: 'Libre Baskerville', serif; font-style: italic; font-size: 18px; color: #6B6258; margin: 0; line-height: 1.6; max-width: 28rem; padding-bottom: 1rem; }
  @media (min-width: 1024px) { .oscar-mission__pull { font-size: 20px; } }

  .oscar-mission__cards { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  @media (min-width: 768px) { .oscar-mission__cards { grid-template-columns: repeat(3, 1fr); gap: 1.5rem; } }

  .oscar-mission__card {
    background: #FFFFFF; border: 1px solid #EFE0C0; border-radius: 1.25rem;
    padding: 2rem; display: flex; flex-direction: column;
    transition: transform 0.3s cubic-bezier(0.22,1,0.36,1), box-shadow 0.3s cubic-bezier(0.22,1,0.36,1);
  }
  .oscar-mission__card:hover { transform: translateY(-6px); box-shadow: 0 12px 32px rgba(0,0,0,0.10); }

  .oscar-mission__num {
    width: 28px; height: 28px; border-radius: 50%; border: 2px solid #C8812E;
    color: #C8812E; font-weight: 900; font-size: 13px;
    display: flex; align-items: center; justify-content: center; margin-bottom: 1.75rem;
  }
  .oscar-mission__card-title { font-family: 'Libre Baskerville', serif; font-weight: 700; font-size: 20px; color: #1A1610; margin: 0 0 1rem; line-height: 1.3; }
  .oscar-mission__card-body { font-weight: 400; font-size: 14px; color: #6B6258; line-height: 1.7; margin: 0; flex: 1; }

  .oscar-mission__more {
    display: inline-flex; align-items: center; gap: 0.375rem;
    margin-top: 1.75rem; text-decoration: none;
    font-weight: 700; font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; color: #C8812E;
  }
  .oscar-mission__more:hover span { text-decoration: underline; }
  .oscar-mission__more svg { transition: transform 0.2s; }
  .oscar-mission__more:hover svg { transform: translate(2px, -2px); }

  .oscar-reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.55s cubic-bezier(0.22,1,0.36,1), transform 0.55s cubic-bezier(0.22,1,0.36,1); }
  .oscar-reveal.is-visible { opacity: 1; transform: translateY(0); }
</style>

<script>
  (function () {
    var els = document.querySelectorAll('#oscar-mission-{{ section.id }} .oscar-reveal');
    if (!('IntersectionObserver' in window)) { els.forEach(function (e) { e.classList.add('is-visible'); }); return; }
    var i = 0;
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (en) {
        if (en.isIntersecting) {
          setTimeout(function(){ en.target.classList.add('is-visible'); }, i * 120);
          i++;
          io.unobserve(en.target);
        }
      });
    }, { rootMargin: '-80px' });
    els.forEach(function (e) { io.observe(e); });
  })();
</script>

{% schema %}
{
  "name": "Oscar Mission",
  "settings": [
    { "type": "text",     "id": "eyebrow",    "label": "Eyebrow",                       "default": "Who We Are" },
    { "type": "textarea", "id": "heading",    "label": "Heading (newlines = lines)",     "default": "Our\nMission" },
    { "type": "textarea", "id": "subheading", "label": "Pull quote (italic)",            "default": "Three commitments that guide every formulation, every sourcing decision, every chew." }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Mission card",
      "settings": [
        { "type": "text",     "id": "number", "label": "Number",      "default": "01" },
        { "type": "text",     "id": "title",  "label": "Title" },
        { "type": "textarea", "id": "body",   "label": "Body" },
        { "type": "url",      "id": "link",   "label": "Read more link" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Oscar Mission",
      "blocks": [
        { "type": "card", "settings": { "number": "01", "title": "Science-backed formulas",     "body": "All formulas are rigorously researched and tested. No unwanted fillers, only 100% concentrated beneficial compounds." } },
        { "type": "card", "settings": { "number": "02", "title": "Premium-sourced ingredients", "body": "We believe our pets should only deserve the best. We prioritize ingredient origin and integrity in every product." } },
        { "type": "card", "settings": { "number": "03", "title": "Every pet wants to be loved", "body": "Pets can't talk, but they want to be loved also. Read our journey and the story behind Oscar Pets." } }
      ]
    }
  ]
}
{% endschema %}
